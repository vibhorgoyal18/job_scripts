<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.vibhorgoyal.naukri_refresh</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/vibhorgoyal/PersonalWorkspace/job_scripts/run_naukri.sh</string>
    </array>

    <!-- Run every day at 9:00 AM local time (set your Mac timezone to IST) -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>9</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/vibhorgoyal/PersonalWorkspace/job_scripts/naukri_refresh.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/vibhorgoyal/PersonalWorkspace/job_scripts/naukri_refresh.log</string>

    <!-- Do NOT run immediately when loaded, only on schedule -->
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
